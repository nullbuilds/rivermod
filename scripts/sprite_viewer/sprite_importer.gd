## Imports a single sprite into an image.
func import(sprite: SpriteSheetFileModel.SpriteModel) -> Image:
	var pixel_color_indices: PackedByteArray = sprite.get_pixel_color_indices()
	var size: Vector2i = sprite.get_size()
	
	var image: Image = Image.create_empty(size.x, size.y, false, Image.FORMAT_RGBA8)
	for column in size.x:
		for row in size.y:
			var pixel_index: int = row * size.x + column
			var pixel_color_index: int = pixel_color_indices.get(pixel_index)
			var color: Color = _DEFAULT_COLOR
			if pixel_color_index < _SPRITE_PALETTE.size():
				color = _SPRITE_PALETTE.get(pixel_color_index)
			
			image.set_pixel(column, row, color)
	
	return image
